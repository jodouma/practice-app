{
  "name": "practice-app-controle-acces-gestion-identite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build && node ./scripts/sync_static_publish.js",
